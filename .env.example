# Exemplo de variáveis de ambiente necessárias para o projeto
# Copie este arquivo para .env e preencha com suas credenciais reais
# O .env real está no .gitignore e NUNCA deve ser commitado

# URL do projeto Supabase (sem /rest/v1/ ou outros sufixos)
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública anon do Supabase (segura para expor no cliente)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
